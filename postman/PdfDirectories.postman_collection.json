{
	"info": {
		"name": "PDF Directories",
		"_postman_id": "pdf-directories-col-etiquecosas-2026",
		"description": "Gestion de directorios de PDF generados al aprobar pedidos. Listado de carpetas por fecha, PDFs por fecha, descarga ZIP y descarga individual. profile_id 1=Admin (ve todo), profile_id 2=Disenador (solo sus carpetas). Formato de fecha en URL: dd-mm-yyyy. Todos los endpoints requieren JWT.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "baseURL",
			"value": "https://api.etiquecosaslab.com.ar/api/",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "GET pdf-directories",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseURL}}pdf-directories",
					"host": [
						"{{baseURL}}pdf-directories"
					],
					"query": [
						{
							"key": "start_date",
							"value": "2026-05-01",
							"description": "Fecha inicio (YYYY-MM-DD)",
							"disabled": true
						},
						{
							"key": "end_date",
							"value": "2026-05-31",
							"description": "Fecha fin (YYYY-MM-DD)",
							"disabled": true
						},
						{
							"key": "user_id",
							"value": "2",
							"description": "Solo para admin: filtrar por disenador",
							"disabled": true
						},
						{
							"key": "per_page",
							"value": "15",
							"description": "Resultados por pagina (default: 15)",
							"disabled": true
						}
					]
				}
			},
			"description": "Lista carpetas de PDF paginadas por fecha (mas reciente primero). Admin ve todo; disenador solo sus carpetas.",
			"response": [
				{
					"name": "200 - Lista de carpetas de PDF",
					"status": "OK",
					"code": 200,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"Directorios obtenidos\",\n  \"data\": [\n    {\n      \"date\": \"26-05-2026\",\n      \"date_formatted\": \"26/05/2026\",\n      \"total_pdfs\": 12,\n      \"user\": {\n        \"id\": 2,\n        \"name\": \"Maria\",\n        \"lastName\": \"Lopez\"\n      }\n    },\n    {\n      \"date\": \"25-05-2026\",\n      \"date_formatted\": \"25/05/2026\",\n      \"total_pdfs\": 8,\n      \"user\": {\n        \"id\": 2,\n        \"name\": \"Maria\",\n        \"lastName\": \"Lopez\"\n      }\n    }\n  ],\n  \"metaData\": {\n    \"current_page\": 1,\n    \"last_page\": 3,\n    \"per_page\": 15,\n    \"total\": 42\n  }\n}"
				},
				{
					"name": "401 - No autenticado",
					"status": "Unauthorized",
					"code": 401,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"Unauthenticated.\"\n}"
				}
			]
		},
		{
			"name": "GET pdf-directories/{fecha}",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseURL}}pdf-directories/26-05-2026",
					"host": [
						"{{baseURL}}pdf-directories/26-05-2026"
					],
					"query": [
						{
							"key": "user_id",
							"value": "2",
							"description": "Solo para admin",
							"disabled": true
						}
					]
				}
			},
			"description": "Retorna todos los PDFs de una fecha en formato dd-mm-yyyy. Incluye pdfs_pedidos y extras (cintas, bandas, sellos).",
			"response": [
				{
					"name": "200 - PDFs de la fecha",
					"status": "OK",
					"code": 200,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"PDFs obtenidos\",\n  \"data\": {\n    \"date\": \"26-05-2026\",\n    \"pdfs_pedidos\": [\n      {\n        \"name\": \"142-etiquetas.pdf\",\n        \"sale_id\": 142,\n        \"size\": \"245KB\"\n      },\n      {\n        \"name\": \"143-stickers.pdf\",\n        \"sale_id\": 143,\n        \"size\": \"189KB\"\n      }\n    ],\n    \"extras\": {\n      \"cintas_coser\": [],\n      \"cintas_planchar\": [\n        {\n          \"name\": \"cintas-26052026.pdf\",\n          \"size\": \"120KB\"\n        }\n      ],\n      \"bandas\": [],\n      \"sellos\": []\n    }\n  }\n}"
				},
				{
					"name": "404 - No encontrado",
					"status": "Not Found",
					"code": 404,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"Directorio no encontrado\"\n}"
				},
				{
					"name": "401 - No autenticado",
					"status": "Unauthorized",
					"code": 401,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"Unauthenticated.\"\n}"
				}
			]
		},
		{
			"name": "GET pdf-directories/{fecha}/download-zip",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseURL}}pdf-directories/26-05-2026/download-zip",
					"host": [
						"{{baseURL}}pdf-directories/26-05-2026/download-zip"
					]
				}
			},
			"description": "Descarga un ZIP con todos los PDFs de la fecha indicada. Organiza en sub-carpetas: pedidos/, cintas_coser/, cintas_planchar/, bandas/, sellos/.",
			"response": [
				{
					"name": "200 - ZIP descargado",
					"status": "OK",
					"code": 200,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/zip"
						},
						{
							"key": "Content-Disposition",
							"value": "attachment; filename=pdfs-26-05-2026.zip"
						}
					],
					"body": "(ZIP binario con sub-carpetas: pedidos/, cintas_coser/, cintas_planchar/, bandas/, sellos/)"
				},
				{
					"name": "404 - No encontrado",
					"status": "Not Found",
					"code": 404,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"Directorio no encontrado\"\n}"
				},
				{
					"name": "401 - No autenticado",
					"status": "Unauthorized",
					"code": 401,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"Unauthenticated.\"\n}"
				}
			]
		},
		{
			"name": "GET pdf-directories/{fecha}/download/{nombrePdf}",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseURL}}pdf-directories/26-05-2026/download/142-etiquetas.pdf",
					"host": [
						"{{baseURL}}pdf-directories/26-05-2026/download/142-etiquetas.pdf"
					]
				}
			},
			"description": "Descarga un PDF individual por nombre. El disenador solo puede descargar PDFs de pedidos que tenga asignados.",
			"response": [
				{
					"name": "200 - PDF individual descargado",
					"status": "OK",
					"code": 200,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/pdf"
						},
						{
							"key": "Content-Disposition",
							"value": "attachment; filename=142-etiquetas.pdf"
						}
					],
					"body": "(PDF binario)"
				},
				{
					"name": "403 - Sin permiso (el disenador no tiene acceso a este PDF)",
					"status": "Forbidden",
					"code": 403,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"No tenes permiso para descargar este PDF\"\n}"
				},
				{
					"name": "404 - No encontrado",
					"status": "Not Found",
					"code": 404,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"PDF no encontrado\"\n}"
				},
				{
					"name": "401 - No autenticado",
					"status": "Unauthorized",
					"code": 401,
					"header": [
						{
							"key": "Content-Type",
							"value": "application/json"
						}
					],
					"body": "{\n  \"message\": \"Unauthenticated.\"\n}"
				}
			]
		}
	]
}